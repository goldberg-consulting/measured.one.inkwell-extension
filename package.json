{
  "name": "inkwell",
  "displayName": "Inkwell",
  "description": "Markdown to publication-quality PDF. Live preview, Pandoc + XeLaTeX compilation, runnable code blocks, and LaTeX template management.",
  "version": "0.1.3",
  "publisher": "measure-one",
  "icon": "media/icon.png",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Notebooks",
    "Programming Languages"
  ],
  "keywords": [
    "markdown",
    "latex",
    "pandoc",
    "pdf",
    "xelatex",
    "academic",
    "preview",
    "literate programming"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/goldberg-consulting/measured.one.inkwell-extension"
  },
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:latex",
    "workspaceContains:.inkwell"
  ],
  "files": [
    "LICENSE",
    "CHANGELOG.md",
    "out/**",
    "templates/**",
    "media/**",
    "examples/*.md",
    "guide.md",
    "requirements-latex.txt",
    ".cursor/agents/inkwell-guide.md"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "inkwell.preview",
        "title": "Inkwell: Open Preview",
        "category": "Inkwell",
        "icon": "$(open-preview)"
      },
      {
        "command": "inkwell.compile",
        "title": "Inkwell: Compile PDF",
        "category": "Inkwell"
      },
      {
        "command": "inkwell.exportPDF",
        "title": "Inkwell: Export PDF to File...",
        "category": "Inkwell"
      },
      {
        "command": "inkwell.selectTemplate",
        "title": "Inkwell: Select LaTeX Template",
        "category": "Inkwell"
      },
      {
        "command": "inkwell.setupToolchain",
        "title": "Inkwell: Check / Install Toolchain (Pandoc, XeLaTeX)",
        "category": "Inkwell"
      },
      {
        "command": "inkwell.runCodeBlocks",
        "title": "Inkwell: Run Code Blocks",
        "category": "Inkwell"
      },
      {
        "command": "inkwell.clearRunCache",
        "title": "Inkwell: Clear Code Block Cache",
        "category": "Inkwell"
      },
      {
        "command": "inkwell.cancelRun",
        "title": "Inkwell: Cancel Running Code Blocks",
        "category": "Inkwell"
      },
      {
        "command": "inkwell.setupPythonEnv",
        "title": "Inkwell: Setup Python Environment (venv)",
        "category": "Inkwell"
      },
      {
        "command": "inkwell.initProject",
        "title": "Inkwell: New Project",
        "category": "Inkwell"
      },
      {
        "command": "inkwell.bootstrapWorkspaceInkwell",
        "title": "Inkwell: Bootstrap Workspace (.inkwell Folder)",
        "category": "Inkwell"
      },
      {
        "command": "inkwell.updateProject",
        "title": "Inkwell: Update Project",
        "category": "Inkwell"
      }
    ],
    "keybindings": [
      {
        "command": "inkwell.preview",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorLangId == markdown || editorLangId == latex"
      },
      {
        "command": "inkwell.compile",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorLangId == markdown || editorLangId == latex"
      },
      {
        "command": "inkwell.runCodeBlocks",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "editorLangId == markdown"
      }
    ],
    "configuration": {
      "title": "Inkwell",
      "properties": {
        "inkwell.autoCompile": {
          "type": "string",
          "enum": [
            "off",
            "onSave",
            "interval"
          ],
          "default": "off",
          "enumDescriptions": [
            "Manual compilation only (use the toolbar button or keybinding)",
            "Compile automatically each time the file is saved",
            "Compile on a repeating timer (see autoCompileIntervalSeconds)"
          ],
          "description": "When to automatically compile the PDF."
        },
        "inkwell.autoCompileIntervalSeconds": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "description": "Seconds between auto-compilations when autoCompile is 'interval'."
        },
        "inkwell.defaultCodeDisplay": {
          "type": "string",
          "enum": [
            "output",
            "both",
            "code",
            "none"
          ],
          "default": "output",
          "enumDescriptions": [
            "Show only the output of code blocks",
            "Show both the source code and its output",
            "Show only the source code",
            "Hide code blocks entirely"
          ],
          "description": "Default visibility for code blocks in compiled output. Can be overridden per-document (inkwell.code-display in frontmatter) or per-block (display attribute)."
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "inkwell.bootstrapWorkspaceInkwell",
          "when": "!inkwell.hasProject"
        }
      ],
      "editor/title": [
        {
          "command": "inkwell.preview",
          "when": "editorLangId == markdown || editorLangId == latex",
          "group": "navigation"
        },
        {
          "command": "inkwell.bootstrapWorkspaceInkwell",
          "when": "(editorLangId == markdown || editorLangId == latex) && !inkwell.hasProject",
          "group": "navigation@1"
        }
      ]
    }
  },
  "scripts": {
    "prepare": "husky",
    "vscode:prepublish": "npm run package",
    "compile": "tsc -p ./",
    "typecheck": "tsc -p ./ --noEmit",
    "watch": "tsc -watch -p ./",
    "package": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=node18 --minify",
    "lint": "eslint src --ext ts",
    "test:regressions": "node scripts/check-template-regressions.mjs",
    "verify": "npm run typecheck && npm run lint && npm run test:regressions"
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.56.1"
  }
}
