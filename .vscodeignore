.git/**
.github/**
.husky/**
src/**
scripts/**
node_modules/**
venv/**
tsconfig.json
eslint.config.mjs
package-lock.json
Brewfile
.pre-commit-config.yaml
.gitignore
*.vsix
# Only the esbuild bundle ships. Excluding out/ wholesale (instead of a
# file-by-file list) prevents newly added modules (e.g. citations.ts,
# frontmatter.ts) from silently leaking tsc output into the VSIX.
# vscode:prepublish rebuilds out/extension.js as a self-contained
# bundle, so nothing else under out/ is needed at runtime.
out/**
!out/extension.js
.cursor/**
# Keep the agent guide that ships with the extension (consumed by the
# Setup Workspace command when .cursor/agents/ exists in the user's
# project).
!.cursor/agents/inkwell-guide.md
# Exclude personal / scratch documents that must never ship to end
# users. Anything matched here is either a local test artifact or
# derivative content that was accidentally tracked in the past.
demo.md
demo.pdf
# guide.md, examples/**, and media/examples/** intentionally SHIP with
# the VSIX: Setup Workspace copies guide.md and examples/*.md into the
# user's project (scaffold.copyGuide / copyDemoFiles), and the example
# PDFs serve as rendered references for each template. Do not re-add
# them here without also changing scaffold.ts to stop promising them.
# Generated artifacts under .inkwell/ (mermaid cache, compiled md,
# outputs directory) are never part of a clean extension bundle.
.inkwell/**
examples/.inkwell/**
